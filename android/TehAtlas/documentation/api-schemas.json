{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Business Management API Schemas",
  "description": "JSON schemas for API request/response validation",

  "definitions": {

    "apiResponse": {
      "type": "object",
      "properties": {
        "success": { "type": "boolean" },
        "message": { "type": "string" },
        "data": { "type": ["object", "array", "null"] }
      },
      "required": ["success", "message"]
    },

    "loginRequest": {
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["username", "password"]
    },

    "loginResponse": {
      "$ref": "#/definitions/apiResponse",
      "properties": {
        "data": {
          "type": "object",
          "properties": {
            "token": { "type": "string" },
            "user": { "$ref": "#/definitions/user" }
          },
          "required": ["token", "user"]
        }
      }
    },

    "user": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "role": { "enum": ["admin", "warehouse", "cashier"] },
        "outlet_id": { "type": ["string", "null"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "role", "created_at", "updated_at"]
    },

    "outletItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "unit_price": { "type": "number", "minimum": 0 },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "sku", "category", "unit_price", "created_at", "updated_at"]
    },

    "saleRequest": {
      "type": "object",
      "properties": {
        "outlet_id": { "type": ["string", "null"] },
        "customer_name": { "type": ["string", "null"] },
        "customer_phone": { "type": ["string", "null"] },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/saleItem" },
          "minItems": 1
        },
        "subtotal": { "type": "number", "minimum": 0 },
        "tax_amount": { "type": "number", "minimum": 0 },
        "discount_amount": { "type": "number", "minimum": 0 },
        "total_amount": { "type": "number", "minimum": 0 },
        "payment_method": { "type": "string" }
      },
      "required": ["items", "subtotal", "tax_amount", "discount_amount", "total_amount", "payment_method"]
    },

    "saleItem": {
      "type": "object",
      "properties": {
        "outlet_item_id": { "type": "string" },
        "quantity": { "type": "integer", "minimum": 1 },
        "unit_price": { "type": "number", "minimum": 0 },
        "total_price": { "type": "number", "minimum": 0 }
      },
      "required": ["outlet_item_id", "quantity", "unit_price", "total_price"]
    },

    "sale": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "receipt_number": { "type": "string" },
        "outlet_id": { "type": "string" },
        "customer_name": { "type": ["string", "null"] },
        "customer_phone": { "type": ["string", "null"] },
        "items": {
          "type": "array",
          "items": { "$ref": "#/definitions/saleItem" }
        },
        "subtotal": { "type": "number" },
        "tax_amount": { "type": "number" },
        "discount_amount": { "type": "number" },
        "total_amount": { "type": "number" },
        "payment_method": { "type": "string" },
        "sale_date": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" }
      },
      "required": ["id", "receipt_number", "outlet_id", "items", "subtotal", "tax_amount", "discount_amount", "total_amount", "payment_method", "sale_date", "created_by"]
    },

    "dashboardData": {
      "type": "object",
      "properties": {
        "today_sales": { "type": "number" },
        "today_sale_count": { "type": "integer" },
        "total_sales": { "type": "number" },
        "total_sale_count": { "type": "integer" },
        "current_inventory": { "type": "integer" },
        "pending_purchases": { "type": "integer" }
      },
      "required": ["today_sales", "today_sale_count", "total_sales", "total_sale_count", "current_inventory", "pending_purchases"]
    },

    "outlet": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "address", "phone", "created_at", "updated_at"]
    },

    "warehouseItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "sku": { "type": "string" },
        "category": { "type": "string" },
        "cost_price": { "type": "number", "minimum": 0 },
        "warehouse_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "sku", "category", "cost_price", "warehouse_id", "created_at", "updated_at"]
    },

    "inventoryTransaction": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "item_id": { "type": "string" },
        "item_type": { "enum": ["warehouse", "outlet"] },
        "transaction_type": { "enum": ["purchase", "sale", "transfer_in", "transfer_out"] },
        "quantity": { "type": "integer" },
        "reference_id": { "type": "string" },
        "reference_type": { "enum": ["purchase", "invoice", "sale"] },
        "warehouse_id": { "type": ["string", "null"] },
        "outlet_id": { "type": ["string", "null"] },
        "transaction_date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "item_id", "item_type", "transaction_type", "quantity", "reference_id", "reference_type", "transaction_date"]
    }
  },

  "examples": {

    "loginRequest": {
      "username": "cashier1",
      "password": "password123"
    },

    "loginResponse": {
      "success": true,
      "message": "Login successful",
      "data": {
        "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
        "user": {
          "id": "507f1f77bcf86cd799439011",
          "username": "cashier1",
          "role": "cashier",
          "outlet_id": "507f1f77bcf86cd799439012",
          "created_at": "2026-02-02T10:00:00.000Z",
          "updated_at": "2026-02-02T10:00:00.000Z"
        }
      }
    },

    "saleRequest": {
      "outlet_id": "507f1f77bcf86cd799439012",
      "customer_name": "John Doe",
      "items": [
        {
          "outlet_item_id": "507f1f77bcf86cd799439013",
          "quantity": 2,
          "unit_price": 15.00,
          "total_price": 30.00
        }
      ],
      "subtotal": 30.00,
      "tax_amount": 3.00,
      "discount_amount": 0.00,
      "total_amount": 33.00,
      "payment_method": "cash"
    },

    "saleResponse": {
      "success": true,
      "message": "Sale created successfully",
      "data": {
        "id": "507f1f77bcf86cd799439014",
        "receipt_number": "RCP-20260202123045",
        "outlet_id": "507f1f77bcf86cd799439012",
        "customer_name": "John Doe",
        "items": [
          {
            "outlet_item_id": "507f1f77bcf86cd799439013",
            "quantity": 2,
            "unit_price": 15.00,
            "total_price": 30.00
          }
        ],
        "subtotal": 30.00,
        "tax_amount": 3.00,
        "discount_amount": 0.00,
        "total_amount": 33.00,
        "payment_method": "cash",
        "sale_date": "2026-02-02T12:30:45.123Z",
        "created_by": "507f1f77bcf86cd799439011"
      }
    },

    "outletItemsResponse": {
      "success": true,
      "message": "",
      "data": [
        {
          "id": "507f1f77bcf86cd799439013",
          "name": "Coffee",
          "description": "Fresh brewed coffee",
          "sku": "COF-001",
          "category": "Beverages",
          "unit_price": 3.50,
          "created_at": "2026-02-02T10:00:00.000Z",
          "updated_at": "2026-02-02T10:00:00.000Z"
        }
      ]
    },

    "dashboardResponse": {
      "success": true,
      "message": "",
      "data": {
        "today_sales": 156.50,
        "today_sale_count": 12,
        "total_sales": 12543.75,
        "total_sale_count": 456,
        "current_inventory": 89,
        "pending_purchases": 3
      }
    },

    "errorResponse": {
      "success": false,
      "message": "Invalid credentials"
    }
  }
}</content>
